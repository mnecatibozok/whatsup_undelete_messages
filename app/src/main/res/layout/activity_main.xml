<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#25D366"
        android:title="@string/app_name"
        android:titleTextColor="#FFFFFF" />

    <LinearLayout
        android:id="@+id/warningBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFF3CD"
        android:padding="12dp"
        android:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bildirim erişim izni verilmedi. Mesajların kaydedilebilmesi için izin vermen gerekiyor."
            android:textColor="#856404"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnPermission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="İzin Ver" />
    </LinearLayout>

    <Button
        android:id="@+id/btnMediaGallery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:text="📷 Medya Galerisi (Fotoğraf / Video)"
        android:backgroundTint="#128C7E"
        android:textColor="#FFFFFF" />

    <EditText
        android:id="@+id/searchBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:padding="10dp"
        android:background="#FFFFFF"
        android:hint="Kişi veya grup adında ara..."
        android:inputType="text" />

    <TextView
        android:id="@+id/emptyView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:text="Henüz kayıtlı sohbet yok.\nWhatsApp mesajları geldikçe kişiler/gruplar burada listelenecek."
        android:textColor="#888888"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/btnClear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:text="Tüm Kayıtları Temizle"
        android:backgroundTint="#D9534F"
        android:textColor="#FFFFFF" />

</LinearLayout>
